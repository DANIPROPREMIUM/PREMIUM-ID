{
  "manifest_version": 3,
  "name": "PREMIUM ID",
  "version": "5.0",
  "description": "Acceso gratuito a cuentas premium.",
  "permissions": [
    "cookies",
    "activeTab",
    "scripting",
    "storage",
    "windows",
    "clipboardRead"
  ],
  "host_permissions": [
    "*://*.netflix.com/*",
    "*://*.crunchyroll.com/*",
    "*://*.primevideo.com/*",
    "*://*.amazon.com/*",
    "*://*.paramountplus.com/*",
    "*://*.viki.com/*",
    "*://*.atresplayer.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*", "*://*.crunchyroll.com/*", "*://*.primevideo.com/*", "*://*.paramountplus.com/*", "*://*.viki.com/*", "*://*.atresplayer.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["bypass-core.js", "netflix-main.js"],
      "css": ["netflix-controller.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "netflix-seeker.js",
        "netflix-audioChange.js",
        "netflix-substitleChange.js"
      ],
      "matches": ["*://*.netflix.com/*"]
    }
  ]
}
